    {
      "id": "graphify",
      "name": "Graphify",
      "category": "Kontext",
      "tier": "recommended",
      "reason": "Grenzt relevanten Projektkontext vor Agentenläufen ein.",
      "detect": { "type": "pythonModule", "module": "graphify" }
    },
    {
      "id": "obsidian",
      "name": "Obsidian",
      "category": "Wissen",
      "tier": "recommended",
      "reason": "Persönliches Arbeitswissen ohne die Repository-Wahrheit zu duplizieren.",
      "detect": { "type": "path", "paths": ["{OBSIDIAN_VAULT}"] },
      "install": { "name": "Obsidian", "command": "winget.exe", "args": ["install", "--id", "Obsidian.Obsidian", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements"] },
      "updateCheck": { "type": "winget", "id": "Obsidian.Obsidian" },
      "update": { "name": "Obsidian", "command": "winget.exe", "args": ["upgrade", "--id", "Obsidian.Obsidian", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements", "--disable-interactivity"] }
    },
    {
      "id": "ecc",
      "name": "ECC",
      "category": "Kontext",
      "tier": "recommended",
      "reason": "Reduziert dauerhaften Agentenkontext und unterstützt gezielte Retrieval-Muster.",
      "detect": { "type": "path", "paths": ["{ECC_ROOT}"] },
      "updateCheck": { "type": "gitRemote", "path": "{ECC_ROOT}", "remote": "origin" },
      "update": { "name": "ECC", "command": "git.exe", "args": ["-C", "{ECC_ROOT}", "pull", "--ff-only"], "preflight": { "type": "cleanGit", "path": "{ECC_ROOT}" } }
    },
    {
      "id": "mcp",
      "name": "MCP",
      "category": "Werkzeugverbindung",
      "tier": "recommended",
      "reason": "Standardisierte lokale Werkzeugverbindungen; MCP selbst verursacht keine Kosten.",
      "detect": { "type": "mcp" }
    },
    {
      "id": "serena",
      "name": "Serena",
      "category": "Code-Kontext",
      "tier": "recommended",
      "reason": "Symbolbasierte Code-Navigation und Referenzsuche, ohne komplette Dateien in den Modellkontext zu laden.",
      "workflowRole": "Semantische Code-Navigation nach der projektweiten Graphify-Eingrenzung.",
      "activation": "Nur bei Codeanalyse, Refactoring und symbolbezogenen Änderungen; aktiviert das aktuelle Arbeitsverzeichnis.",
      "costPolicy": "Lokal und Open Source; nutzt das bereits gewählte LLM und erzeugt kein eigenes Abo.",
      "detect": { "type": "command", "command": "serena.exe", "args": ["--version"] },
      "install": { "name": "Serena", "command": "uv.exe", "args": ["tool", "install", "-p", "3.13", "serena-agent"] }
    },
    {
      "id": "cli-continues",
      "name": "cli-continues",
      "category": "Provider-Übergabe",
      "tier": "recommended",
      "reason": "Liest lokale Codex- und Claude-Sitzungen read-only und ergänzt Übergaben bei einem echten Kontingentwechsel.",
      "workflowRole": "Kompaktes Sitzungsartefakt zusätzlich zu Task-Paket, Logs und Git-Diff.",
      "activation": "Nur nach einem erkannten Codex- oder Claude-Kontingentlimit; niemals als stiller Sitzungswähler.",
      "costPolicy": "Lokal und Open Source; startet keinen kostenpflichtigen Provider selbstständig.",
      "detect": { "type": "pathOrCommand", "paths": ["{APPDATA}\\npm\\continues.cmd"], "command": "continues.cmd", "args": ["--version"] },
      "install": { "name": "cli-continues", "command": "npm.cmd", "args": ["install", "--global", "continues"] },
      "updateCheck": { "type": "npm", "package": "continues" },
      "update": { "name": "cli-continues", "command": "npm.cmd", "args": ["install", "--global", "continues@latest"] }
    },
