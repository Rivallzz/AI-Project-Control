      "install": { "name": "Claude Code", "command": "npm.cmd", "args": ["install", "--global", "@anthropic-ai/claude-code"] },
      "updateCheck": { "type": "npm", "package": "@anthropic-ai/claude-code" },
      "update": { "name": "Claude Code", "command": "npm.cmd", "args": ["install", "--global", "@anthropic-ai/claude-code@latest"] }
    },
    {
      "id": "hermes",
      "name": "Hermes Agent",
      "category": "Orchestrierung",
      "tier": "recommended",
      "reason": "Kontrollierte Orchestrierung komplexer, mehrstufiger Aufgaben.",
      "detect": { "type": "command", "command": "hermes.exe", "args": ["--version"] }
    },
    {
      "id": "ollama",
