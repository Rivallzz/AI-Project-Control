      "updateCheck": { "type": "winget", "id": "Ollama.Ollama" },
      "update": { "name": "Ollama", "command": "winget.exe", "args": ["upgrade", "--id", "Ollama.Ollama", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements", "--disable-interactivity"] }
    },
    {
      "id": "python",
      "name": "Python",
      "category": "Runtime",
      "tier": "recommended",
      "reason": "Basis für Graphify, lokale Analyse und Automatisierung.",
      "detect": { "type": "command", "command": "python.exe", "args": ["--version"] },
      "install": { "name": "Python 3.12", "command": "winget.exe", "args": ["install", "--id", "Python.Python.3.12", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements"] },
      "updateCheck": { "type": "winget", "id": "Python.Python.3.12" },
      "update": { "name": "Python 3.12", "command": "winget.exe", "args": ["upgrade", "--id", "Python.Python.3.12", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements", "--disable-interactivity"] }
    },
    {
      "id": "uv",
      "name": "uv",
      "category": "Runtime",
      "tier": "recommended",
      "reason": "Reproduzierbare, schnelle Python-Umgebungen.",
      "detect": { "type": "command", "command": "uv.exe", "args": ["--version"] },
      "install": { "name": "uv", "command": "winget.exe", "args": ["install", "--id", "astral-sh.uv", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements"] },
      "updateCheck": { "type": "winget", "id": "astral-sh.uv" },
      "update": { "name": "uv", "command": "winget.exe", "args": ["upgrade", "--id", "astral-sh.uv", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements", "--disable-interactivity"] }
