{
  "schemaVersion": 2,
  "systems": [
    {
      "id": "node",
      "name": "Node.js",
      "category": "Runtime",
      "tier": "required",
      "reason": "Laufzeit des lokalen Dashboards.",
      "detect": { "type": "command", "command": "node.exe", "args": ["--version"] },
      "install": { "name": "Node.js LTS", "command": "winget.exe", "args": ["install", "--id", "OpenJS.NodeJS.LTS", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements"] },
      "updateCheck": { "type": "winget", "id": "OpenJS.NodeJS.LTS" },
      "update": { "name": "Node.js LTS", "command": "winget.exe", "args": ["upgrade", "--id", "OpenJS.NodeJS.LTS", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements", "--disable-interactivity"] }
    },
    {
      "id": "git",
      "name": "Git",
      "category": "Entwicklung",
      "tier": "required",
      "reason": "Versionskontrolle, Branches und sichere Worktrees.",
