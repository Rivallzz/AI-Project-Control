      "install": { "name": "PowerShell 7", "command": "winget.exe", "args": ["install", "--id", "Microsoft.PowerShell", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements"] },
      "updateCheck": { "type": "winget", "id": "Microsoft.PowerShell" },
      "update": { "name": "PowerShell 7", "command": "winget.exe", "args": ["upgrade", "--id", "Microsoft.PowerShell", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements", "--disable-interactivity"] }
    },
    {
      "id": "codex",
      "name": "Codex CLI",
      "category": "KI-Agent",
      "tier": "recommended",
      "reason": "Primärer Coding-Agent mit bestehendem ChatGPT-Kontingent.",
      "detect": { "type": "command", "command": "codex.exe", "args": ["--version"] },
      "install": { "name": "Codex CLI", "command": "npm.cmd", "args": ["install", "--global", "@openai/codex"] },
      "updateCheck": { "type": "npm", "package": "@openai/codex" },
      "update": { "name": "Codex CLI", "command": "npm.cmd", "args": ["install", "--global", "@openai/codex@latest"] }
    },
    {
      "id": "claude",
