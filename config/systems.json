      "install": { "name": "Git", "command": "winget.exe", "args": ["install", "--id", "Git.Git", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements"] },
      "updateCheck": { "type": "winget", "id": "Git.Git" },
      "update": { "name": "Git", "command": "winget.exe", "args": ["upgrade", "--id", "Git.Git", "--exact", "--silent", "--accept-package-agreements", "--accept-source-agreements", "--disable-interactivity"] }
    },
    {
